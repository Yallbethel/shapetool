<?xml version="1.0" encoding="UTF-8"?>

<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema"
           targetNamespace="http://example.org/shapetool"
           xmlns:tns="http://example.org/shapetool"
           elementFormDefault="qualified">

    <!-- ========================= -->
    <!-- COMMON TYPE DEFINITIONS  -->
    <!-- ========================= -->

    <!-- Positive number restriction -->
    <xs:simpleType name="positiveDouble">
        <xs:restriction base="xs:double">
            <xs:minExclusive value="0"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- ========================= -->
    <!-- CIRCLE                   -->
    <!-- ========================= -->

    <xs:element name="circleAreaRequest">
        <xs:complexType>
            <xs:sequence>
                <xs:element name="radius" type="tns:positiveDouble"/>
            </xs:sequence>
        </xs:complexType>
    </xs:element>

    <xs:element name="circleAreaResponse">
        <xs:complexType>
            <xs:sequence>
                <xs:element name="area" type="xs:double"/>
            </xs:sequence>
        </xs:complexType>
    </xs:element>

    <!-- ========================= -->
    <!-- SQUARE                   -->
    <!-- ========================= -->

    <xs:element name="squareAreaRequest">
        <xs:complexType>
            <xs:sequence>
                <xs:element name="side" type="tns:positiveDouble"/>
            </xs:sequence>
        </xs:complexType>
    </xs:element>

    <xs:element name="squareAreaResponse">
        <xs:complexType>
            <xs:sequence>
                <xs:element name="area" type="xs:double"/>
            </xs:sequence>
        </xs:complexType>
    </xs:element>

    <!-- ========================= -->
    <!-- RECTANGLE                -->
    <!-- ========================= -->

    <xs:element name="rectangleAreaRequest">
        <xs:complexType>
            <xs:sequence>
                <xs:element name="length" type="tns:positiveDouble"/>
                <xs:element name="width" type="tns:positiveDouble"/>
            </xs:sequence>
        </xs:complexType>
    </xs:element>

    <xs:element name="rectangleAreaResponse">
        <xs:complexType>
            <xs:sequence>
                <xs:element name="area" type="xs:double"/>
            </xs:sequence>
        </xs:complexType>
    </xs:element>

    <!-- ========================= -->
    <!-- TRIANGLE                 -->
    <!-- ========================= -->

    <xs:element name="triangleAreaRequest">
        <xs:complexType>
            <xs:sequence>
                <xs:element name="base" type="tns:positiveDouble"/>
                <xs:element name="height" type="tns:positiveDouble"/>
            </xs:sequence>
        </xs:complexType>
    </xs:element>

    <xs:element name="triangleAreaResponse">
        <xs:complexType>
            <xs:sequence>
                <xs:element name="area" type="xs:double"/>
            </xs:sequence>
        </xs:complexType>
    </xs:element>

    <!-- ========================= -->
    <!-- PARALLELOGRAM            -->
    <!-- ========================= -->

    <xs:element name="parallelogramAreaRequest">
        <xs:complexType>
            <xs:sequence>
                <xs:element name="base" type="tns:positiveDouble"/>
                <xs:element name="height" type="tns:positiveDouble"/>
            </xs:sequence>
        </xs:complexType>
    </xs:element>

    <xs:element name="parallelogramAreaResponse">
        <xs:complexType>
            <xs:sequence>
                <xs:element name="area" type="xs:double"/>
            </xs:sequence>
        </xs:complexType>
    </xs:element>

</xs:schema>